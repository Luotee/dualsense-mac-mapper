{
  "_help": [
    "Edit the 'buttons' section to remap. Change 'type' to one of:",
    "  - 'key'      : set 'value' to a key name from _keyboard_keys below",
    "  - 'macro'    : set 'value' to a macro name defined in 'macros'",
    "  - 'mouse'    : set 'value' to one of: 'left', 'middle', 'right', 'wheel-up', 'wheel-down'",
    "  - 'unbound'  : do nothing (omit 'value')",
    "Ids 25..=28 are the four touchpad quadrants (TL/TR/BL/BR).",
    "Set 'touchpad_cursor_enabled' to false to disable the cursor; sensitivity is in [0.1, 10.0].",
    "'touchpad_midpoint_x' / 'touchpad_midpoint_y' set the quadrant boundary in raw pad coords (default 960/540 = centre of a 1920x1080 pad). If the wrong quadrant fires on click, watch the debug dot in the GUI to see the captured raw position, then tune these values.",
    "Restart the exe after editing — there is no hot reload in v0.1.x.",
    "Fields starting with '_' are documentation only and ignored by the program."
  ],
  "_keyboard_keys": {
    "letters_and_digits": [
      "Any single ASCII character is the physical key of the same letter or digit.",
      "Examples: \"x\", \"X\", \"a\", \"0\", \"9\". Case does not matter."
    ],
    "modifiers":   ["Shift", "Control", "Ctrl", "Alt", "Meta", "Win", "Cmd"],
    "modifiers_lr": ["LShift", "RShift", "LControl", "LCtrl", "RControl", "RCtrl", "LAlt", "RAlt"],
    "arrows":      ["Up", "Down", "Left", "Right"],
    "edit_keys":   ["Space", "Enter", "Return", "Tab", "Escape", "Esc", "Backspace", "Delete", "Del"],
    "navigation":  ["Home", "End", "PageUp", "PageDown"],
    "function":    ["F1", "F2", "F3", "F4", "F5", "F6", "F7", "F8", "F9", "F10", "F11", "F12"],
    "punctuation": ["-", "=", "[", "]", "\\", ";", "'", ",", ".", "/", "`"],
    "note": "Unknown key names fail loudly at startup — the validator names the bad binding."
  },

  "version": 1,
  "deadzone": 0.4,
  "trigger_threshold": 0.5,
  "min_press_ms": [8, 25],
  "tick_jitter_ms": [0, 3],
  "log_events": true,
  "buttons": {
    "0":  { "label": "Cross（叉叉）",            "type": "key",     "value": "Alt" },
    "1":  { "label": "Circle（圈圈）",           "type": "key",     "value": "z" },
    "2":  { "label": "Square（正方形）",         "type": "key",     "value": "Shift" },
    "3":  { "label": "Triangle（三角）",         "type": "key",     "value": "a" },
    "4":  { "label": "Share（拍照鍵）",          "type": "unbound" },
    "5":  { "label": "PS 按鈕",                  "type": "key",     "value": "Space" },
    "6":  { "label": "Options（Menu 鍵）",       "type": "key",     "value": "Enter" },
    "7":  { "label": "L3",                       "type": "unbound" },
    "8":  { "label": "R3",                       "type": "unbound" },
    "9":  { "label": "L1",                       "type": "unbound" },
    "10": { "label": "R1",                       "type": "unbound" },
    "11": { "label": "D-pad ↑",                  "type": "key",     "value": "Up" },
    "12": { "label": "D-pad ↓",                  "type": "key",     "value": "Down" },
    "13": { "label": "D-pad ←",                  "type": "key",     "value": "Left" },
    "14": { "label": "D-pad →",                  "type": "key",     "value": "Right" },
    "15": { "label": "L-stick ↑",                "type": "key",     "value": "Up" },
    "16": { "label": "L-stick ↓",                "type": "key",     "value": "Down" },
    "17": { "label": "L-stick ←",                "type": "key",     "value": "Left" },
    "18": { "label": "L-stick →",                "type": "key",     "value": "Right" },
    "19": { "label": "R-stick ↑",                "type": "unbound" },
    "20": { "label": "R-stick ↓",                "type": "unbound" },
    "21": { "label": "R-stick ←",                "type": "unbound" },
    "22": { "label": "R-stick →",                "type": "unbound" },
    "23": { "label": "L2（類比板機）",           "type": "unbound" },
    "24": { "label": "R2（類比板機）",           "type": "key",     "value": "Shift" },
    "25": { "label": "Touchpad TL",              "type": "mouse",   "value": "left" },
    "26": { "label": "Touchpad TR",              "type": "mouse",   "value": "left" },
    "27": { "label": "Touchpad BL",              "type": "mouse",   "value": "left" },
    "28": { "label": "Touchpad BR",              "type": "mouse",   "value": "left" }
  },
  "touchpad_cursor_enabled": true,
  "touchpad_cursor_sensitivity": 1.5,
  "touchpad_midpoint_x": 960,
  "touchpad_midpoint_y": 540,
  "macros": {
    "macro_A": {
      "loop": true,
      "steps": [
        { "key": "Left",  "action": "down", "delay_ms": [50, 80] },
        { "key": "Left",  "action": "up",   "delay_ms": [15, 25] },
        { "key": "Right", "action": "down", "delay_ms": [50, 60] },
        { "key": "Right", "action": "up",   "delay_ms": [15, 25] }
      ]
    }
  }
}
