{
  "version": 1,
  "deadzone": 0.4,
  "trigger_threshold": 0.5,
  "min_press_ms": [8, 25],
  "tick_jitter_ms": [0, 3],
  "log_events": true,
  "buttons": {
    "0":  { "label": "Cross (X)",          "type": "key",     "value": "x" },
    "1":  { "label": "Circle (O)",         "type": "key",     "value": "3" },
    "2":  { "label": "Square ([])",        "type": "key",     "value": "z" },
    "3":  { "label": "Triangle (^)",       "type": "unbound" },
    "4":  { "label": "Share",              "type": "unbound" },
    "5":  { "label": "PS Button",          "type": "unbound" },
    "6":  { "label": "Options",            "type": "unbound" },
    "7":  { "label": "L3 (stick click)",   "type": "unbound" },
    "8":  { "label": "R3 (stick click)",   "type": "unbound" },
    "9":  { "label": "L1",                 "type": "key",     "value": "1" },
    "10": { "label": "R1",                 "type": "key",     "value": "Shift" },
    "11": { "label": "D-pad Up",           "type": "key",     "value": "Up" },
    "12": { "label": "D-pad Down",         "type": "key",     "value": "Down" },
    "13": { "label": "D-pad Left",         "type": "key",     "value": "Left" },
    "14": { "label": "D-pad Right",        "type": "key",     "value": "Right" },
    "15": { "label": "L-stick Up",         "type": "key",     "value": "Up" },
    "16": { "label": "L-stick Down",       "type": "key",     "value": "Down" },
    "17": { "label": "L-stick Left",       "type": "key",     "value": "Left" },
    "18": { "label": "L-stick Right",      "type": "key",     "value": "Right" },
    "19": { "label": "R-stick Up",         "type": "unbound" },
    "20": { "label": "R-stick Down",       "type": "unbound" },
    "21": { "label": "R-stick Left",       "type": "unbound" },
    "22": { "label": "R-stick Right",      "type": "unbound" },
    "23": { "label": "L2 trigger",         "type": "macro",   "value": "macro_A" },
    "24": { "label": "R2 trigger",         "type": "key",     "value": "a" }
  },
  "macros": {
    "macro_A": {
      "loop": true,
      "steps": [
        { "key": "Left",  "action": "down", "delay_ms": [50, 80] },
        { "key": "Left",  "action": "up",   "delay_ms": [15, 25] },
        { "key": "Right", "action": "down", "delay_ms": [50, 60] },
        { "key": "Right", "action": "up",   "delay_ms": [15, 25] }
      ]
    }
  }
}
